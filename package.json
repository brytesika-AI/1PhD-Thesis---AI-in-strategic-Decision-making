{
  "name": "ai-srf-cloudflare-first",
  "private": true,
  "type": "module",
  "scripts": {
    "check:worker": "node --check apps/worker/src/index.js",
    "test:worker": "node --test tests/cloudflare-worker/*.test.mjs",
    "deploy:worker": "wrangler deploy --config apps/worker/wrangler.toml",
    "deploy:pages": "wrangler pages deploy apps/web --project-name ai-srf-cloudflare --branch main",
    "d1:migrate": "wrangler d1 execute AI_SRF_SENSING --remote --file apps/worker/schema.sql"
  }
}
