# AI-SRF Environment Variables

# Provider: ollama | huggingface_inference | github_models | openai_compatible
MODEL_PROVIDER=ollama
MODEL_NAME=llama3.1:latest

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# RAG & Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# API Keys (Optional)
HUGGINGFACE_API_KEY=
GITHUB_MODELS_API_KEY=
ANTHROPIC_API_KEY=

# App Settings
PORT=8000
SECTOR=generic
LOG_LEVEL=INFO
